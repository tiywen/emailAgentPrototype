// 设计原因：脏数据输入（转发链 + HTML噪音 + 长签名）。
// 测试指标：summary抗噪、triage提取核心请求、reply不受噪音污染。
{
  "id": "tc09",
  "scenario_type": "noisy_formatting_forward_chain",
  "input": {
    "user_context": {
      "user_role": "manager",
      "working_hours": "09:00-18:00",
      "important_senders": [],
      "usual_external_priority": "medium"
    },
    "thread": {
      "thread_id": "tc09",
      "subject": "Fwd: RE: RE: Contract review",
      "messages": [
        {
          "sender": {
            "email": "legal.ops@company.com",
            "display_name": "Legal Ops",
            "relationship": "peer"
          },
          "recipients": ["you@company.com"],
          "timestamp": "2026-03-25T13:45:00Z",
          "body": "-----Forwarded message-----\n<div>Hi team,<br>Please review the latest clause update and confirm today if acceptable.</div>\n\nRegards,\nLegal Ops\n--\nConfidentiality Notice...\n\n<img src='cid:logo'>"
        }
      ]
    }
  },
  "expected_output": {
    "triage": {
      "needs_response": true,
      "allowed_priority": ["MEDIUM", "HIGH"],
      "disallowed_priority": ["LOW"],
      "expected_signal_assertions": {
        "has_request": true,
        "has_deadline": true
      },
      "expected_score_band": [4, 20],
      "reason_must_include_any": ["请求", "确认", "高优先级"]
    },
    "summary": {
      "must_capture": ["review", "clause update", "confirm today"],
      "must_not_hallucinate": ["Confidentiality Notice as action item", "image attachment required"],
      "expected_key_points_count_range": [1, 10],
      "expected_open_questions": [],
      "short_summary_max_chars": 280,
      "long_summary_min_chars": 60
    },
    "reply": {
      "should_generate": true,
      "tone": "professional_neutral",
      "must_include": ["review", "confirm"],
      "must_not_include": ["cid:logo", "confidentiality notice"],
      "max_length_category": "short"
    }
  }
}
