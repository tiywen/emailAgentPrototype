// 设计原因：多意图邮件（FYI + request + scheduling）避免“平均化”误判。
// 测试指标：multi-intent识别、priority稳健性、reply行为。
{
  "id": "tc07",
  "input": {
    "thread_id": "tc07",
    "subject": "Plan update + quick review + scheduling",
    "messages": [
      {
        "sender": "teammate@company.com",
        "recipients": ["you@company.com"],
        "timestamp": "2026-03-25T09:30:00Z",
        "body": "FYI, we finished the latest draft. Could you quickly review section 2 and let us know if 4pm tomorrow works for a sync?"
      }
    ]
  },
  "expected_output": {
    "是否需要回复": true,
    "回复草稿规则": "non_empty",
    "signals": {
      "has_request": true,
      "has_deadline": false
    },
    "score_band": {
      "min": 2,
      "max": 6
    },
    "priority_rule": {
      "allowed": ["MEDIUM", "UNCERTAIN", "HIGH"],
      "forbidden": ["LOW"]
    }
  }
}
