// 设计原因：UNCERTAIN制度化场景1：弱请求 + 角色不清 + 无deadline。
// 测试指标：在低把握度下优先不确定，避免错误自信分类。
{
  "id": "tc03",
  "input": {
    "thread_id": "tc03",
    "subject": "Thoughts?",
    "messages": [
      {
        "sender": "teammate@company.com",
        "recipients": ["you@company.com"],
        "timestamp": "2026-03-25T11:20:00Z",
        "body": "Let me know your thoughts when you have a moment."
      }
    ]
  },
  "expected_output": {
    "是否需要回复": true,
    "回复草稿规则": "non_empty",
    "判断原因应包含": ["priority=UNCERTAIN"],
    "signals": {
      "has_deadline": false,
      "requires_response": ["可能需要"]
    },
    "score_band": {
      "min": 1,
      "max": 4
    },
    "priority_rule": {
      "allowed": ["UNCERTAIN", "MEDIUM"],
      "forbidden": ["LOW"]
    }
  }
}
