// 设计原因：验证“礼貌措辞但业务紧迫（客户会议前）”的隐性紧急场景识别。
// 测试指标：Failure mode验证、High-priority precision。
{
  "id": "tc10",
  "input": {
    "thread_id": "tc10",
    "subject": "Feedback before customer meeting",
    "messages": [
      {
        "sender": "partner_lead@partner.com",
        "recipients": ["you@company.com"],
        "timestamp": "2026-03-25T06:50:00Z",
        "body": "Would really appreciate your feedback by end of day, since we have a customer meeting tomorrow morning."
      }
    ]
  },
  "expected_output": {
    "是否需要回复": true,
    "回复草稿规则": "non_empty",
    "判断原因应包含": ["priority=HIGH"]
  }
}
