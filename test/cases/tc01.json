// 设计原因：高风险必判高（manager + request + deadline）。
// 测试指标：signal抽取正确性、score区间、priority稳定性、reply行为一致性。
{
  "id": "tc01",
  "input": {
    "thread_id": "tc01",
    "subject": "Final deck before 5pm",
    "messages": [
      {
        "sender": "Alice (Manager)",
        "recipients": ["you@company.com"],
        "timestamp": "2026-03-25T08:30:00Z",
        "body": "Please send me the final deck by 5pm today. This is urgent for the steering meeting."
      }
    ]
  },
  "expected_output": {
    "是否需要回复": true,
    "回复草稿规则": "non_empty",
    "判断原因应包含": ["priority=HIGH"],
    "signals": {
      "sender_importance": ["manager"],
      "has_request": true,
      "has_deadline": true,
      "requires_response": ["明确需要", "可能需要"]
    },
    "score_band": {
      "min": 6
    },
    "priority_rule": {
      "allowed": ["HIGH"]
    }
  }
}
