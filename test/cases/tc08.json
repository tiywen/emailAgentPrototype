// 设计原因：sender ambiguity（老板助理代发）。
// 测试指标：triage角色识别、summary不漏“on behalf of VP”、reply语气谨慎。
{
  "id": "tc08",
  "scenario_type": "sender_ambiguity_delegate_mail",
  "input": {
    "user_context": {
      "user_role": "manager",
      "working_hours": "09:00-18:00",
      "important_senders": ["vp.li@company.com"],
      "usual_external_priority": "medium"
    },
    "thread": {
      "thread_id": "tc08",
      "subject": "On behalf of VP: pre-read confirmation",
      "messages": [
        {
          "sender": {
            "email": "assistant.office@company.com",
            "display_name": "Office Assistant",
            "relationship": "unknown"
          },
          "recipients": ["you@company.com"],
          "timestamp": "2026-03-25T07:10:00Z",
          "body": "Sending this on behalf of VP Li. Please confirm you have read the pre-read before tomorrow 10:00."
        }
      ]
    }
  },
  "expected_output": {
    "triage": {
      "needs_response": true,
      "allowed_priority": ["MEDIUM", "HIGH"],
      "disallowed_priority": ["LOW"],
      "expected_signal_assertions": {
        "has_request": true,
        "has_deadline": true
      },
      "expected_score_band": [4, 20],
      "reason_must_include_any": ["请求", "明天10:00", "确认阅读"]
    },
    "summary": {
      "must_capture": ["on behalf of VP", "confirm", "tomorrow 10:00"],
      "must_not_hallucinate": ["contract approval", "no response needed"],
      "expected_key_points_count_range": [1, 8],
      "expected_open_questions": [],
      "short_summary_max_chars": 260,
      "long_summary_min_chars": 50
    },
    "reply": {
      "should_generate": true,
      "tone": "professional_neutral",
      "must_include": ["确认", "预读材料"],
      "must_not_include": ["ignore"],
      "max_length_category": "short"
    }
  }
}
