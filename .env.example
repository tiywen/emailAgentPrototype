OPENAI_API_KEY=
# Optional default for Streamlit / CLI
OPENAI_MODEL=gpt-4o-mini

# Microsoft Entra public client (Streamlit device code login)
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
# Optional: authority URL (overrides AZURE_TENANT_ID in the login host path). Examples:
# Single tenant: https://login.microsoftonline.com/<your-tenant-guid>
# Work + personal (MSA) mail: https://login.microsoftonline.com/common
# Personal-only: https://login.microsoftonline.com/consumers
# AZURE_AUTHORITY=
# Optional: national cloud login host (default login.microsoftonline.com)
# AZURE_LOGIN_HOST=login.microsoftonline.com
# Optional: set true if corporate proxy breaks instance discovery (AADSTS700016 / wrong metadata)
# AZURE_MSAL_DISABLE_INSTANCE_DISCOVERY=true

# Microsoft Graph API root (must match your tenant cloud; wrong host often causes HTTP 401)
# GRAPH_API_ROOT=https://graph.microsoft.com/v1.0
# China: https://microsoftgraph.chinacloudapi.cn/v1.0
# US Gov: https://graph.microsoft.us/v1.0
# Aliases also supported:
# MICROSOFT_CLIENT_ID=
# MICROSOFT_TENANT_ID=
